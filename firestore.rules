rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == "komoe.work@gmail.com"
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Pillar 2: Validation Blueprints
    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'baseSalary']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.baseSalary is number && data.baseSalary >= 0 &&
             (!data.keys().hasAny(['authUid']) || data.authUid is string) &&
             (!data.keys().hasAny(['loginEmail']) || data.loginEmail is string) &&
             (!data.keys().hasAny(['hasAuth']) || data.hasAuth is bool);
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['employeeName', 'timestamp', 'selfie']) &&
             data.keys().size() >= 3 &&
             data.employeeName is string && data.employeeName.size() > 0 &&
             data.timestamp == request.time &&
             data.selfie is string && data.selfie.size() <= 1048576; // 1MB limit
    }

    function isValidPayroll(data) {
      return data.keys().hasAll(['employeeName', 'month', 'totalSalary']) &&
             data.month is string && data.month.matches('^[0-9]{4}-[0-9]{2}$') &&
             data.totalSalary is number;
    }

    // Phase 4: Match Blocks
    
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidEmployee(incoming()) && isValidId(employeeId);
      allow update: if isAdmin() && isValidEmployee(incoming()) && 
                    incoming().name == existing().name &&
                    incoming().diff(existing()).affectedKeys().hasAny(['authUid', 'hasAuth', 'loginEmail', 'baseSalary', 'role', 'email']);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAttendance(incoming()) && isValidId(attendanceId);
      allow update: if false; // Attendance is immutable
      allow delete: if isAdmin();
    }

    match /payroll/{payrollId} {
      allow read: if isSignedIn(); // Or restrict to admins
      allow create: if isAdmin() && isValidPayroll(incoming()) && isValidId(payrollId);
      allow update: if isAdmin() && isValidPayroll(incoming()) &&
                    (incoming().status != 'paid' || existing().status != 'paid'); // Prevent editing paid records
      allow delete: if isAdmin();
    }
  }
}
